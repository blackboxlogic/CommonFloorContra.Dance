{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "clean (functions)",
            "command": "dotnet",
            "args": [
                "clean",
                "/property:GenerateFullPaths=true",
                "/consoleloggerparameters:NoSummary"
            ],
            "type": "process",
            "problemMatcher": "$msCompile",
            "options": {
                "cwd": "${workspaceFolder}/ProxyByRegex"
            }
        },
        {
            "label": "build (functions)",
            "command": "dotnet",
            "args": [
                "build",
                "/property:GenerateFullPaths=true",
                "/consoleloggerparameters:NoSummary"
            ],
            "type": "process",
            "dependsOn": "clean (functions)",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": "$msCompile",
            "options": {
                "cwd": "${workspaceFolder}/ProxyByRegex"
            }
        },
        {
            "label": "clean release (functions)",
            "command": "dotnet",
            "args": [
                "clean",
                "--configuration",
                "Release",
                "/property:GenerateFullPaths=true",
                "/consoleloggerparameters:NoSummary"
            ],
            "type": "process",
            "problemMatcher": "$msCompile",
            "options": {
                "cwd": "${workspaceFolder}/ProxyByRegex"
            }
        },
        {
            "label": "publish (functions)",
            "command": "dotnet",
            "args": [
                "publish",
                "--configuration",
                "Release",
                "/property:GenerateFullPaths=true",
                "/consoleloggerparameters:NoSummary"
            ],
            "type": "process",
            "dependsOn": "clean release (functions)",
            "problemMatcher": "$msCompile",
            "options": {
                "cwd": "${workspaceFolder}/ProxyByRegex"
            }
        },
        {
            "type": "func",
            "label": "func: host start",
            "dependsOn": ["kill-func", "build (functions)"],
            "options": {
                "cwd": "${workspaceFolder}/ProxyByRegex/bin/Debug/net8.0"
            },
            "command": "func host start",
            "isBackground": true,
            "problemMatcher": "$func-dotnet-watch",
            "windows": {
                "options": {
                    "shell": {
                        "executable": "cmd.exe",
                        "args": [ "/c" ]
                    }
                }
            }
        }, {
            "label": "kill-func",
            "command": "taskkill",
            "args": [
                "/F",
                "/IM",
                "func.exe"
            ],
            "type": "process",
            "problemMatcher": []
        },
        {
            "label": "clean (EventsViewer)",
            "command": "dotnet",
            "args": [
                "clean",
                "/property:GenerateFullPaths=true",
                "/consoleloggerparameters:NoSummary"
            ],
            "type": "process",
            "problemMatcher": "$msCompile",
            "options": {
                "cwd": "${workspaceFolder}/EventsViewer"
            }
        },
        {
            "label": "build (EventsViewer)",
            "command": "dotnet",
            "args": [
                "build",
                "/property:GenerateFullPaths=true",
                "/consoleloggerparameters:NoSummary"
            ],
            "type": "process",
            "dependsOn": "clean (EventsViewer)",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": "$msCompile",
            "options": {
                "cwd": "${workspaceFolder}/EventsViewer"
            }
        },
        {
            "label": "watch (EventsViewer.Client)",
            "command": "dotnet",
            "type": "process",
            "args": [
                "watch",
                "run",
                "--project",
                "${workspaceFolder}/EventsViewer.Client/EventsViewer.Client.csproj"
            ],
            "problemMatcher": "$msCompile",
            "isBackground": true,
            "dependsOn": ["build (EventsViewer.Client)"]
        },
        {
            "label": "build (EventsViewer.Client)",
            "command": "dotnet",
            "type": "process",
            "args": [
                "build",
                "${workspaceFolder}/EventsViewer.Client/EventsViewer.Client.csproj",
                "/property:GenerateFullPaths=true",
                "/consoleloggerparameters:NoSummary"
            ],
            "problemMatcher": "$msCompile"
        }
    ]
}
