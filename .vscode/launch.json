{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Run API",
            "type": "coreclr",
            "request": "attach",
            "processId": "${command:azureFunctions.pickProcess}"
        },
        {
            "name": "Run Viewer",
            "type": "coreclr",
            "request": "launch",
            "program": "dotnet",
            "args": [
                "watch",
                "--project",
                "${workspaceFolder}/EventsViewer/EventsViewer.csproj"
            ],
            "cwd": "${workspaceFolder}/EventsViewer",
            "stopAtEntry": false,
            "serverReadyAction": {
                "action": "openExternally",
                "pattern": "\\bNow listening on:\\s+(https?://\\S+)"
            },
            "env": {
                "ASPNETCORE_ENVIRONMENT": "Development"
            },
            "sourceFileMap": {
                "/Views": "${workspaceFolder}/Views"
            }
        }
    ],
    "compounds": [
        {
            "name": "Run All",
            "configurations": ["Run API", "Run Viewer"]
        }
    ]
}