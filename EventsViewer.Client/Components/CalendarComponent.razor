@inject IJSRuntime JSRuntime
<h3>Calendar Component</h3>
<div id="calendar"></div>

@code {
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JSRuntime.InvokeVoidAsync("calendarInterop.init", "calendar");
        }
    }

    @* public async Task UpdateCalendar(string[] states)
    {
        await JSRuntime.InvokeVoidAsync("calendarInterop.update", states);
    } *@
}
